# ===========================================
# Bilibala Environment Variables
# Copy this file to .env.local and fill in your values
# ===========================================

# Node Environment (set to 'production' on Railway)
NODE_ENV=development

# Server Configuration
PORT=3001
HOST=0.0.0.0

# ===========================================
# Google Gemini AI
# ===========================================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_API_VERSION=v1alpha  # Optional

# ===========================================
# Supadata (YouTube Transcripts)
# ===========================================
SUPADATA_API_KEY=your_supadata_api_key

# ===========================================
# DeepL Translation
# ===========================================
DEEPL_API_KEY=your_deepl_api_key

# ===========================================
# Supabase (Database & Auth)
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Frontend also needs these (with VITE_ prefix)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# ===========================================
# Stripe (Payments)
# ===========================================
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs
STRIPE_PRO_PRICE_ID=price_monthly_id
STRIPE_PRO_ANNUAL_PRICE_ID=price_annual_id
STRIPE_STARTER_PACK_PRICE_ID=price_starter_pack_id
STRIPE_TOPUP_PRICE_ID=price_topup_id
